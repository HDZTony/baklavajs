{
    "name": "@baklavajs/events",
    "version": "2.8.0",
    "description": "Implementation of the Baklava event system. Mainly intended for internal use in the Baklava ecosystem",
    "author": "newcat <freddy.wagner@web.de>",
    "homepage": "https://github.com/newcat/baklavajs#readme",
    "license": "MIT",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "scripts": {
        "build:esm": "esbuild src/*.ts --outdir=dist/esm --format=esm --sourcemap",
        "build:cjs": "esbuild src/*.ts --outdir=dist/cjs --format=cjs --sourcemap",
        "build:types": "tsc -p tsconfig.build.json",
        "build": "rimraf dist && pnpm run build:esm && pnpm run build:cjs && pnpm run build:types && node -e \"require('fs').writeFileSync('dist/esm/package.json','{\\\"type\\\":\\\"module\\\"}')\" && node -e \"require('fs').writeFileSync('dist/cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\""
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/newcat/baklavajs.git"
    },
    "bugs": {
        "url": "https://github.com/newcat/baklavajs/issues"
    },
    "devDependencies": {
        "typescript": "^6.0.2"
    }
}
